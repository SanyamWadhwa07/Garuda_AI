[Unit]
Description=GarudaAI Local AI Agent Platform
Documentation=https://github.com/garudaai/garudaai
After=network-online.target
Wants=network-online.target garudaai-ollama.service

[Service]
Type=simple
User=%u
ExecStart=/usr/local/bin/garudaai serve
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/.cache/garudaai %h/.local/share/garudaai %h/.config/garudaai

[Install]
WantedBy=default.target
